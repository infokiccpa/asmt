PORT=5000

# MongoDB (required). Example Atlas:
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/DATABASE?retryWrites=true&w=majority
# Render: set this in the dashboard (Environment). Do not wrap the value in quotes.
MONGODB_URI=

# Firebase Admin SDK — base64-encode your serviceAccountKey.json:
#   Windows PowerShell: [Convert]::ToBase64String([IO.File]::ReadAllBytes("src/config/serviceAccountKey.json"))
#   Mac/Linux:          base64 -i src/config/serviceAccountKey.json
FIREBASE_SERVICE_ACCOUNT=

# OpenAI
OPENAI_API_KEY=

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://your-app.web.app,https://your-app.firebaseapp.com

# Shared secret between Node backend and Python extraction service.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Set the same value as INTERNAL_API_KEY in the Python service environment,
# and as NEXT_PUBLIC_PYTHON_API_KEY in the frontend environment.
INTERNAL_API_KEY=

# One-time bootstrap secret for POST /api/auth/bootstrap-super-admin.
# Used only when no Super Admin exists yet. Remove or leave blank after first use.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BOOTSTRAP_SECRET=
